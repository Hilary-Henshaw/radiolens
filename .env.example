# radiolens environment configuration
# Copy to .env and fill in values as needed.
# All variables are prefixed with RADIOLENS_ unless noted.

# ── API Server ────────────────────────────────────────────────────────────────
# Listening host and port (PORT overrides RADIOLENS_API_PORT on Render/Railway)
PORT=8000
RADIOLENS_API_HOST=0.0.0.0

# Path to trained model weights file (.keras or .h5)
RADIOLENS_MODEL_WEIGHTS_PATH=model/best_weights.keras

# Max upload size in bytes (default: 10 MB)
RADIOLENS_MAX_UPLOAD_BYTES=10485760

# Comma-separated list of allowed CORS origins (* = all)
# RADIOLENS_CORS_ALLOW_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── Model Architecture ────────────────────────────────────────────────────────
RADIOLENS_IMAGE_HEIGHT=224
RADIOLENS_IMAGE_WIDTH=224
RADIOLENS_DENSE_LAYER_UNITS=128
RADIOLENS_FIRST_DROPOUT_RATE=0.3
RADIOLENS_SECOND_DROPOUT_RATE=0.2

# ── Training ──────────────────────────────────────────────────────────────────
RADIOLENS_BATCH_SIZE=32
RADIOLENS_MAX_EPOCHS=25
RADIOLENS_INITIAL_LEARNING_RATE=0.001
RADIOLENS_EARLY_STOP_PATIENCE=7
RADIOLENS_RANDOM_SEED=42

# ── Dataset Splits ────────────────────────────────────────────────────────────
RADIOLENS_TRAIN_FRACTION=0.7
RADIOLENS_VALIDATION_FRACTION=0.2
RADIOLENS_TEST_FRACTION=0.1

# ── Bootstrap Statistical Testing ─────────────────────────────────────────────
RADIOLENS_BOOTSTRAP_RESAMPLES=1000
RADIOLENS_BOOTSTRAP_CI_LEVEL=0.95
